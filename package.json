{
  "name": "client-backend",
  "version": "0.0.1",
  "description": "Wenex Client",
  "author": "Vahid V. <vhid.vz@gmail.com>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "prepare": "npm run script:setup",
    "prepare:platform": "npm run platform:seed && npm run platform:raise",
    "script:setup": "sh ./script/setup.sh",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:debug2": "nest start --debug 9228 --watch",
    "start:prod": "node dist/apps/client-backend/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/client-backend/test/jest-e2e.json",
    "command": "node -r tsconfig-paths/register -r ts-node/register libs/command/src/main.ts",
    "command:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register libs/command/src/main.ts",
    "platform:clean": "npm run command -- platform clean",
    "platform:seed": "npm run command -- platform seed",
    "platform:raise": "npm run command -- platform raise",
    "platform:debug": "npm run command:debug -- platform"
  },
  "dependencies": {
    "@nestjs/axios": "^3.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/graphql": "^12.0.11",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/terminus": "^10.2.0",
    "@ntegral/nestjs-sentry": "^4.0.0",
    "@opentelemetry/auto-instrumentations-node": "^0.40.2",
    "@opentelemetry/exporter-trace-otlp-http": "^0.46.0",
    "@opentelemetry/exporter-zipkin": "^1.19.0",
    "@opentelemetry/instrumentation": "^0.46.0",
    "@opentelemetry/instrumentation-amqplib": "^0.33.4",
    "@opentelemetry/instrumentation-express": "^0.34.0",
    "@opentelemetry/instrumentation-grpc": "^0.46.0",
    "@opentelemetry/instrumentation-http": "^0.46.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.33.3",
    "@opentelemetry/resources": "^1.19.0",
    "@opentelemetry/sdk-node": "^0.46.0",
    "@opentelemetry/sdk-trace-node": "^1.19.0",
    "@opentelemetry/semantic-conventions": "^1.19.0",
    "@wenex/sdk": "^0.2.4",
    "@willsoto/nestjs-prometheus": "^6.0.0",
    "abacl": "^8.0.5",
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "log": "^6.3.1",
    "log-node": "^8.0.3",
    "mongodb": "^6.3.0",
    "naming-conventions-modeler": "^1.4.1",
    "nest-commander": "^3.12.5",
    "phone": "^3.1.41",
    "qs": "^6.11.2",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/log": "^6.3.3",
    "@types/node": "^20.10.5",
    "@types/qs": "^6.9.10",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.15.0",
    "npm": ">=9.5.0"
  }
}
