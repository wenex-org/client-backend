REGION=IR
TZ=Asia/Tehran

# *****************************
# Logging Services
# *****************************

# Logging
LOG_DEBUG=*
LOG_LEVEL=notice

# Sentry
SENTRY_DSN=
SENTRY_MAX_BREADCRUMBS=10
SENTRY_TRACES_SAMPLE_RATE=1.0

