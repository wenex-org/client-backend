DEBUG=false
NODE_ENV=develop

# *****************************
# Platform Configuration
# *****************************

STRICT_TOKEN=false

PLATFORM_URL=http://localhost:3010

# *****************************
# Internationalization
# *****************************

EXCEPTION_LANG='en'

DEFAULT_TIMEZONE='Asia/Tehran'

# *****************************
# Logging Services
# *****************************

# Logging
LOG_DEBUG=*
LOG_LEVEL=notice

# Sentry
SENTRY_DSN=
SENTRY_MAX_BREADCRUMBS=10
SENTRY_TRACES_SAMPLE_RATE=1.0

# **********************
# Storage Services
# **********************

# Mongo
MONGO_DB=wenex-client

MONGO_USER=root
MONGO_PASS=password123
MONGO_HOST=mongodb-primary:27017,mongodb-secondary:27018,mongodb-arbiter:27019
MONGO_QUERY="replicaSet=rs0&authSource=admin"

