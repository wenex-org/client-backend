DEBUG=false
TIMEOUT=90000
NODE_ENV=develop

# *****************************
# Platform Configuration
# *****************************

STRICT_TOKEN=false

PLATFORM_URL=http://localhost:3010

# **********************
# Internationalization
# **********************

